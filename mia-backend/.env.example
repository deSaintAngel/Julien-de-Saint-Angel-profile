
# Configuration pub rewardée (optionnel)
PUB_API_KEY=votre_clé_pub_ici

# Configuration JWT (optionnel, pour sessions sécurisées)
JWT_SECRET=votre_secret_jwt_ici

# Configuration serveur
PORT=3000
NODE_ENV=production

# CORS (domaines autorisés, séparés par des virgules)
ALLOWED_ORIGINS=https://desaintangel.github.io,http://localhost:8080

# --- Anti-abus / limitation de débit (toutes optionnelles, valeurs par défaut sûres) ---
# Limite globale sur /api/* : nb max de requêtes par IP et par fenêtre
API_RATE_MAX=100
API_RATE_WINDOW_MIN=5
# Limite stricte sur le chat (chaque message = 1 appel LLM)
CHAT_RATE_MAX=30
CHAT_RATE_WINDOW_MIN=5
# Limite très stricte sur l'envoi d'e-mails
MAIL_RATE_MAX=3
MAIL_RATE_WINDOW_MIN=60
# Plafond GLOBAL d'appels LLM par jour (circuit-breaker : borne le coût max)
GLOBAL_DAILY_LLM_MAX=2000

# --- E-mail ---
# Destinataire des e-mails de discussion (codé côté serveur, jamais fourni par le client)
MIA_MAIL_TO=julien.desaintangel@gmail.com


